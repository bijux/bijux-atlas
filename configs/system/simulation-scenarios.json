{
  "schema_version": 1,
  "registry_id": "system-simulation-scenarios",
  "scenarios": [
    {
      "id": "fresh-install",
      "description": "Install the platform from an empty environment.",
      "command": "bijux-dev-atlas system simulate install"
    },
    {
      "id": "upgrade-previous-release",
      "description": "Upgrade an existing environment from the previous release.",
      "command": "bijux-dev-atlas system simulate upgrade"
    },
    {
      "id": "rollback-after-failed-upgrade",
      "description": "Rollback to the previous state when an upgrade fails.",
      "command": "bijux-dev-atlas system simulate rollback"
    },
    {
      "id": "offline-mode",
      "description": "Validate runtime behavior without external network dependencies.",
      "command": "bijux-dev-atlas system simulate offline-mode"
    }
  ]
}
