{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/datasets/ingest-run.schema.json",
  "title": "Ingest Run Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_id",
    "timing_ms",
    "outputs",
    "contracts"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "timing_ms": {
      "type": "number",
      "minimum": 0
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "INGEST-002"
      ],
      "properties": {
        "INGEST-002": {
          "type": "boolean"
        }
      }
    }
  }
}
