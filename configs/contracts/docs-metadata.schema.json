{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocsMetadata",
  "type": "object",
  "required": ["owner", "status", "last_verified", "scope"],
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "stable"]
    },
    "last_verified": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
