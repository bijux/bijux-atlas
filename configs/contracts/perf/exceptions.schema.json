{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Performance Exceptions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exceptions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "metric",
          "expires_on",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "expires_on": {
            "type": "string",
            "format": "date"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
