{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Performance Benches Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy",
    "benches"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "macro_default_enabled"
      ],
      "properties": {
        "macro_default_enabled": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "benches": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "weight",
          "default_enabled"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "weight": {
            "type": "string",
            "enum": [
              "micro",
              "macro"
            ]
          },
          "default_enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
