{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "release_manifest",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "git_sha",
    "build_time",
    "artifact_list",
    "control_plane_version",
    "ops_profiles_validated",
    "docs_build_hash",
    "sbom_digests",
    "container_image_digests",
    "chart"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "git_sha": {
      "type": "string",
      "minLength": 1
    },
    "build_time": {
      "type": "string",
      "minLength": 1
    },
    "artifact_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "size_bytes"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "control_plane_version": {
      "type": "string",
      "minLength": 1
    },
    "ops_profiles_validated": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs_build_hash": {
      "type": "string",
      "minLength": 1
    },
    "sbom_digests": {
      "type": "array"
    },
    "container_image_digests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chart": {
      "type": "object",
      "required": [
        "version",
        "path",
        "sha256"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "security_advisories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
