{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "artifact_list": {
      "items": {
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "minLength": 1,
            "type": "string"
          },
          "size_bytes": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "path",
          "sha256",
          "size_bytes"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "build_metadata": {
      "properties": {
        "architecture": {
          "minLength": 1,
          "type": "string"
        },
        "cargo_profile": {
          "minLength": 1,
          "type": "string"
        },
        "os": {
          "minLength": 1,
          "type": "string"
        },
        "toolchain_versions": {
          "type": "object"
        }
      },
      "required": [
        "os",
        "architecture",
        "cargo_profile",
        "toolchain_versions"
      ],
      "type": "object"
    },
    "build_time": {
      "minLength": 1,
      "type": "string"
    },
    "chart": {
      "properties": {
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "minLength": 1,
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "version",
        "path",
        "sha256"
      ],
      "type": "object"
    },
    "container_image_digests": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "control_plane_version": {
      "minLength": 1,
      "type": "string"
    },
    "docs_build_hash": {
      "minLength": 1,
      "type": "string"
    },
    "git_sha": {
      "minLength": 1,
      "type": "string"
    },
    "ops_profiles_validated": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "sbom_digests": {
      "type": "array"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "security_advisories": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "version",
    "git_sha",
    "build_time",
    "artifact_list",
    "control_plane_version",
    "build_metadata",
    "ops_profiles_validated",
    "docs_build_hash",
    "sbom_digests",
    "container_image_digests",
    "chart"
  ],
  "title": "release_manifest",
  "type": "object"
}
