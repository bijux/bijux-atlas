{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/governance/suite-baseline.schema.json",
  "title": "Suite Baseline Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_id",
    "owner",
    "suites"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "baseline_id": {
      "type": "string",
      "const": "suite-baseline"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "suite_id",
          "expected_total",
          "minimum_group_counts"
        ],
        "properties": {
          "suite_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "expected_total": {
            "type": "integer",
            "minimum": 1
          },
          "minimum_group_counts": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}
