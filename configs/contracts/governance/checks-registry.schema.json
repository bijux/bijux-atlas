{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/governance/checks-registry.schema.json",
  "title": "Checks Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "registry_id": {
      "type": "string",
      "const": "checks-registry"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "summary",
          "owner",
          "mode",
          "group",
          "inputs",
          "outputs",
          "commands",
          "reports",
          "suite_membership",
          "severity",
          "stage",
          "runtime_cost",
          "determinism"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^CHECK-[A-Z0-9-]+$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "pure",
              "effect"
            ]
          },
          "group": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "reports": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "replaces": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "since_version": {
            "type": "string",
            "minLength": 1
          },
          "retries": {
            "type": "integer",
            "minimum": 0
          },
          "requires_tools": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "missing_tools_policy": {
            "type": "string",
            "enum": [
              "fail",
              "skip"
            ]
          },
          "suite_membership": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "major",
              "minor",
              "info"
            ]
          },
          "stage": {
            "type": "string",
            "enum": [
              "local",
              "pr",
              "merge",
              "release"
            ]
          },
          "runtime_cost": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "determinism": {
            "type": "string",
            "enum": [
              "strict",
              "bounded",
              "best-effort"
            ]
          }
        }
      }
    }
  }
}
