{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/governance/contracts-registry.schema.json",
  "title": "Contracts Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "contracts"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "registry_id": {
      "type": "string",
      "const": "contracts-registry"
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contract_id",
          "summary",
          "owner",
          "mode",
          "runner",
          "reports",
          "suite_membership"
        ],
        "properties": {
          "contract_id": {
            "type": "string",
            "pattern": "^[A-Z0-9-]+$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "pure",
              "effect"
            ]
          },
          "runner": {
            "type": "string",
            "minLength": 1
          },
          "reports": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "suite_membership": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    }
  }
}
