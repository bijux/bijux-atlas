{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/governance/suites-index.schema.json",
  "title": "Governance Suites Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "index_id", "owner", "suites"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "index_id": { "type": "string", "const": "governance-suites" },
    "owner": { "type": "string", "minLength": 1 },
    "suites": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+\\.suite\\.json$"
      }
    }
  }
}
