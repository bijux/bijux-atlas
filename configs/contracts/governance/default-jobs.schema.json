{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/governance/repository/default-jobs.schema.json",
  "title": "Suite Default Jobs Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "owner",
    "suites"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "policy_id": {
      "type": "string",
      "const": "suite-default-jobs"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "suite_id",
          "auto_jobs",
          "low_core_cap",
          "high_mem_parallelism",
          "effect_parallelism"
        ],
        "properties": {
          "suite_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "auto_jobs": {
            "type": "integer",
            "minimum": 1
          },
          "low_core_cap": {
            "type": "integer",
            "minimum": 1
          },
          "high_mem_parallelism": {
            "type": "integer",
            "minimum": 1
          },
          "effect_parallelism": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
