{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/governance/contract-modes.schema.json",
  "title": "Contract Modes",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_set_id", "static_ids", "effect_ids"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "contract_set_id": {
      "type": "string",
      "const": "contract-modes"
    },
    "static_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9-]+$"
      },
      "uniqueItems": true
    },
    "effect_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9-]+$"
      },
      "uniqueItems": true
    }
  }
}
