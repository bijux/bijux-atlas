{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/redaction.schema.json",
  "title": "Security Redaction Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "replacement"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "replacement": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
