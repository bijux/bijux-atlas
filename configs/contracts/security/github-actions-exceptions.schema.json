{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/github-actions-exceptions.schema.json",
  "title": "GitHub Actions Exceptions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exceptions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workflow_path",
          "action",
          "reason",
          "owner",
          "expires_on"
        ],
        "properties": {
          "workflow_path": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "expires_on": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    }
  }
}
