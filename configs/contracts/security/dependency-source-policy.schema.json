{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/dependency-source-policy.schema.json",
  "title": "Dependency Source Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "npm",
    "python",
    "github_actions",
    "images",
    "sbom"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "npm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_registries",
        "lockfile_paths"
      ],
      "properties": {
        "allowed_registries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "lockfile_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "python": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_indexes",
        "requirements_paths"
      ],
      "properties": {
        "allowed_indexes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "requirements_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "github_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_dir",
        "toolchain_inventory",
        "exceptions_path",
        "require_sha_pins"
      ],
      "properties": {
        "workflow_dir": {
          "type": "string",
          "minLength": 1
        },
        "toolchain_inventory": {
          "type": "string",
          "minLength": 1
        },
        "exceptions_path": {
          "type": "string",
          "minLength": 1
        },
        "require_sha_pins": {
          "type": "boolean"
        }
      }
    },
    "images": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolchain_inventory",
        "bases_lock",
        "evidence_manifest",
        "require_digest_pins"
      ],
      "properties": {
        "toolchain_inventory": {
          "type": "string",
          "minLength": 1
        },
        "bases_lock": {
          "type": "string",
          "minLength": 1
        },
        "evidence_manifest": {
          "type": "string",
          "minLength": 1
        },
        "require_digest_pins": {
          "type": "boolean"
        }
      }
    },
    "sbom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_manifest",
        "required_formats",
        "require_prod_profiles"
      ],
      "properties": {
        "evidence_manifest": {
          "type": "string",
          "minLength": 1
        },
        "required_formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "require_prod_profiles": {
          "type": "boolean"
        }
      }
    }
  }
}
