{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schemas/security/auth-model.schema.json",
  "title": "Auth Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "default_stance",
    "auth_support",
    "supported_methods",
    "runtime_auth_mode_env",
    "recommended_auth_placement",
    "deployment_boundary_requirement",
    "docs"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "default_stance": {
      "type": "string",
      "enum": ["public", "internal", "zero-trust"]
    },
    "auth_support": {
      "type": "string",
      "enum": ["no-auth", "supported"]
    },
    "supported_methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["disabled", "api-key", "hmac", "mTLS", "oidc"]
      },
      "uniqueItems": true
    },
    "runtime_auth_mode_env": {
      "type": "string",
      "pattern": "^ATLAS_[A-Z0-9_]+$"
    },
    "recommended_auth_placement": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["ingress-proxy", "service-mesh", "sidecar", "built-in"]
      },
      "uniqueItems": true
    },
    "deployment_boundary_requirement": {
      "type": "string",
      "minLength": 1
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "runbook"],
      "properties": {
        "model": {
          "type": "string",
          "pattern": "^docs/.+\\.md$"
        },
        "runbook": {
          "type": "string",
          "pattern": "^docs/.+\\.md$"
        }
      }
    }
  }
}
