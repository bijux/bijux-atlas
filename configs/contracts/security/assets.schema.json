{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/assets.schema.json",
  "title": "Security Asset Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assets"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "description",
          "sensitivity",
          "owner"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "data",
              "credential",
              "endpoint",
              "artifact"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "sensitivity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
