{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schemas/security/principals.schema.json",
  "title": "Security Principals Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "principals"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "principals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "audience", "expectation"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z-]*$"
          },
          "audience": {
            "type": "string",
            "enum": ["human", "workload", "admin", "automation"]
          },
          "expectation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
