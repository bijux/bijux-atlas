{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/controls.schema.json",
  "title": "Security Controls Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "controls"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CTRL-[A-Z0-9-]+$"
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
