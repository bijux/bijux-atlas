{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/contracts/reports/closure-summary.schema.json",
  "title": "closure-summary report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "version",
    "inputs",
    "checks",
    "status"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "docs-build-closure-summary"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "inputs": {
      "type": "object"
    },
    "checks": {
      "type": "array"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    }
  }
}
