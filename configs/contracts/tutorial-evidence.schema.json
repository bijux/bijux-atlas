{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "configs/contracts/tutorial-evidence.schema.json",
  "title": "Tutorial Real Data Evidence Bundle",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "dataset",
    "atlas_version",
    "git_sha",
    "runtime_profile",
    "environment",
    "tool_versions",
    "provenance",
    "ingest",
    "storage",
    "queries",
    "health",
    "logs",
    "failure_classification"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "dataset": {"type": "string", "minLength": 1},
    "atlas_version": {"type": "string", "minLength": 1},
    "git_sha": {"type": "string", "minLength": 1},
    "runtime_profile": {"type": "string", "minLength": 1},
    "environment": {
      "type": "object",
      "required": ["os", "arch"],
      "properties": {
        "os": {"type": "string"},
        "arch": {"type": "string"}
      },
      "additionalProperties": true
    },
    "tool_versions": {"type": "object"},
    "provenance": {"type": "object"},
    "ingest": {"type": "object"},
    "storage": {"type": "object"},
    "queries": {"type": "array"},
    "health": {"type": "object"},
    "logs": {"type": "object"},
    "failure_classification": {"type": "string"}
  },
  "additionalProperties": true
}
