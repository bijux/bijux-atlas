{
  "schema_version": 1,
  "owner": "team:atlas-governance",
  "mappings": [
    {
      "topic": "root_markdown_surface",
      "policy": "configs/sources/repository/layout/root-markdown-allowlist.json",
      "applies_to": ["CHECK-DOCS-ROOT-*", "CHECK-OPS-ROOT-*"]
    },
    {
      "topic": "markdown_outside_docs",
      "policy": "configs/sources/repository/docs/allowed-non-docs-markdown.json",
      "applies_to": ["CHECK-DOCS-OPS-*", "CHECK-DOCS-INDEX-*"]
    },
    {
      "topic": "ops_markdown_classes",
      "policy": "configs/sources/repository/docs/ops-markdown-classes.json",
      "applies_to": ["CHECK-OPS-DOCS-*", "CHECK-OPS-GOV-*"]
    },
    {
      "topic": "generated_file_minification",
      "policy": "configs/sources/repository/layout/generated-files.json",
      "applies_to": ["CHECK-DOCS-GENERATED-*", "CHECK-CONFIGS-GENERATED-*"]
    },
    {
      "topic": "global_governance_enforcement",
      "policy": "configs/sources/governance/governance/governance.json",
      "applies_to": ["*"]
    }
  ]
}
