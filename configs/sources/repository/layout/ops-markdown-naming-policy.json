{
  "schema_version": 1,
  "policy_id": "ops.markdown.naming",
  "default_standard": "SNAKE_UPPER",
  "canonical_filenames": [
    "README.md",
    "INDEX.md",
    "CONTRACT.md",
    "ERRORS.md",
    "SSOT.md"
  ],
  "exceptions": [],
  "rule": "Ops markdown is limited to five root documents with canonical uppercase filenames."
}
