{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/observability/retention.schema.json",
  "title": "Observability Retention Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "target",
          "retention_days",
          "max_size_bytes",
          "rotation_count",
          "access_model"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "retention_days": {
            "type": "integer",
            "minimum": 1
          },
          "max_size_bytes": {
            "type": "integer",
            "minimum": 1
          },
          "rotation_count": {
            "type": "integer",
            "minimum": 1
          },
          "access_model": {
            "type": "string",
            "enum": [
              "operator-only"
            ]
          }
        }
      }
    }
  }
}
