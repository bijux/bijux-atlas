{
  "schema_version": 1,
  "cluster_id": "atlas-prod-eu1",
  "node_id": "atlas-node-1",
  "generation": 1,
  "role": "hybrid",
  "advertise_addr": "http://atlas-node-1.internal:8080",
  "capabilities": [
    "ingest.pipeline",
    "query.execute",
    "query.cache",
