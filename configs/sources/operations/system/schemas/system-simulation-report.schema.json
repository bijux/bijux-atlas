{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "system_simulation_report",
  "type": "object",
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "kind": {"type": "string", "const": "system_simulation_report"},
    "scenario": {"type": "object"},
    "status": {"type": "string"},
    "deterministic_order": {"type": "integer"},
    "duration_seconds": {"type": "integer", "minimum": 0},
    "time_budget_ok": {"type": "boolean"},
    "reproducibility_contract": {"type": "object"},
    "injections": {"type": "array"},
    "evidence": {"type": "object"}
  },
  "required": [
    "schema_version",
    "kind",
    "scenario",
    "status",
    "deterministic_order",
    "duration_seconds",
    "time_budget_ok",
    "reproducibility_contract",
    "injections",
    "evidence"
  ]
}
