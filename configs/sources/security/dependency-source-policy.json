{
  "schema_version": 1,
  "npm": {
    "allowed_registries": [
      "https://registry.npmjs.org/"
    ],
    "lockfile_paths": [
      "configs/sources/repository/docs/package-lock.json"
    ]
  },
  "python": {
    "allowed_indexes": [
      "https://pypi.org/simple",
      "https://pypi.org/simple/"
    ],
    "requirements_paths": [
      "configs/sources/repository/docs/requirements.txt",
      "configs/sources/repository/docs/requirements.lock.txt"
    ]
  },
  "dependency_lock_posture": {
    "rust": {
      "required": true,
      "lockfile_path": "Cargo.lock"
    },
    "npm": {
      "required": true,
      "lockfile_paths": [
        "configs/sources/repository/docs/package-lock.json"
      ]
    },
    "python": {
      "required": true,
      "lockfile_paths": [
        "configs/sources/repository/docs/requirements.lock.txt"
      ]
    },
    "helm": {
      "required": false,
      "lockfile_paths": [
        "ops/k8s/charts/bijux-atlas/Chart.lock"
      ]
    }
  },
  "github_actions": {
    "workflow_dir": ".github/workflows",
    "toolchain_inventory": "ops/inventory/toolchain.json",
    "exceptions_path": "configs/sources/security/github-actions-exceptions.json",
    "require_sha_pins": true
  },
  "images": {
    "toolchain_inventory": "ops/inventory/toolchain.json",
    "bases_lock": "ops/docker/bases.lock",
    "evidence_manifest": "ops/release/evidence/manifest.json",
    "require_digest_pins": true
  },
  "sbom": {
    "evidence_manifest": "ops/release/evidence/manifest.json",
    "required_formats": [
      "spdx-json",
      "cyclonedx-json"
    ],
    "require_prod_profiles": true
  }
}
