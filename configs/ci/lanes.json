{
  "schema_version": 1,
  "concurrency_classes": {
    "small": {
      "max_parallelism": 2
    },
    "medium": {
      "max_parallelism": 4
    },
    "large": {
      "max_parallelism": 8
    }
  },
  "timeout_classes": {
    "small": {
      "max_minutes": 30
    },
    "medium": {
      "max_minutes": 60
    },
    "large": {
      "max_minutes": 120
    }
  },
  "lanes": [
    {
      "id": "ci-nightly",
      "description": "Nightly extended validation lane",
      "mode": "verify",
      "aliases": [],
      "required_env": [
        "CARGO_TERM_COLOR"
      ],
      "artifacts_expected": [
        "reports/ci-nightly.json",
        "reports/docs-reference-generate.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/ci-nightly.json",
      "timeout_class": "large",
      "concurrency_class": "large",
      "command": "bijux dev atlas ci report --kind lane-parity --format json"
    },
    {
      "id": "ci-pr-fast",
      "description": "Fast pull request validation",
      "mode": "verify",
      "aliases": [
        "ci-fast"
      ],
      "required_env": [
        "CARGO_TERM_COLOR"
      ],
      "artifacts_expected": [
        "reports/governance-validate.json",
        "reports/governance-coverage-diff.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/ci-pr-fast.json",
      "timeout_class": "medium",
      "concurrency_class": "medium",
      "command": "bijux dev atlas ci verify workflow-policy --format json"
    },
    {
      "id": "ci-pr-full",
      "description": "Full pull request policy and workflow checks",
      "mode": "verify",
      "aliases": [
        "ci-pr",
        "supply-chain"
      ],
      "required_env": [
        "CARGO_TERM_COLOR"
      ],
      "artifacts_expected": [
        "reports/ci-pr.json",
        "reports/docs-ssot-reference-drift.json",
        "reports/repo-write-drift.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/ci-pr-full.json",
      "timeout_class": "large",
      "concurrency_class": "large",
      "command": "bijux dev atlas ci verify workflow-lint --format json"
    },
    {
      "id": "dependency-lock",
      "description": "Dependency lock discipline lane",
      "mode": "verify",
      "aliases": [],
      "required_env": [
        "CARGO_TERM_COLOR"
      ],
      "artifacts_expected": [
        "reports/dependency-lock-verify.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/dependency-lock.json",
      "timeout_class": "small",
      "concurrency_class": "small",
      "command": "bijux dev atlas ci verify dependency-lock --allow-git --format json"
    },
    {
      "id": "docs-audit",
      "description": "Documentation audit and policy enforcement lane",
      "mode": "verify",
      "aliases": [],
      "required_env": [
        "CARGO_TERM_COLOR"
      ],
      "artifacts_expected": [
        "reports/docs.json",
        "reports/docs-audit.json",
        "reports/docs-test-coverage.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/docs-audit.json",
      "timeout_class": "medium",
      "concurrency_class": "small",
      "command": "bijux dev atlas ci verify docs-preview --allow-subprocess --allow-write --format json"
    },
    {
      "id": "docs-only",
      "description": "Documentation-only verification lane",
      "mode": "verify",
      "aliases": [
        "docs"
      ],
      "required_env": [
        "CARGO_TERM_COLOR"
      ],
      "artifacts_expected": [
        "reports/docs.json",
        "reports/docs-diff-summary.json",
        "reports/docs-test-coverage.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/docs-only.json",
      "timeout_class": "small",
      "concurrency_class": "small",
      "command": "bijux dev atlas ci verify docs-preview --allow-subprocess --allow-write --format json"
    },
    {
      "id": "ops-kind-integration",
      "description": "Kind integration and smoke lane",
      "mode": "effect",
      "aliases": [
        "ops-kind"
      ],
      "required_env": [
        "KUBECONFIG"
      ],
      "artifacts_expected": [
        "reports/ops-kind-up.json",
        "reports/ops-k8s-smoke.json",
        "reports/ops-kind-down.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/ops-kind-integration.json",
      "timeout_class": "large",
      "concurrency_class": "large",
      "command": "bijux dev atlas ci verify workflow-policy --format json"
    },
    {
      "id": "ops-validate",
      "description": "Operations manifest validation lane",
      "mode": "verify",
      "aliases": [],
      "required_env": [
        "CARGO_TERM_COLOR"
      ],
      "artifacts_expected": [
        "reports/ops-validate.json",
        "reports/ops-k8s-render.json",
        "reports/ops-inventory-validate.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/ops-validate.json",
      "timeout_class": "medium",
      "concurrency_class": "medium",
      "command": "bijux dev atlas ci report --kind lane-parity --format json"
    },
    {
      "id": "release-candidate",
      "description": "Release candidate contract lane",
      "mode": "verify",
      "aliases": [],
      "required_env": [
        "GITHUB_REF"
      ],
      "artifacts_expected": [
        "reports/release-check.json",
        "reports/release-candidate.json",
        "reports/ops-readiness.json"
      ],
      "evidence_bundle": "artifacts/ci/evidence/release-candidate.json",
      "timeout_class": "large",
      "concurrency_class": "medium",
      "command": "bijux dev atlas ci verify release-candidate --allow-git --format json"
    }
  ]
}
