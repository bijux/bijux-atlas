{
  "schema_version": 1,
  "registry_id": "checks-registry",
  "checks": [
    {
      "check_id": "CHECK-RUSTFMT-001",
      "summary": "Verify Rust source formatting stays aligned with the pinned rustfmt policy.",
      "owner": "team:atlas-platform",
      "mode": "pure",
      "inputs": [
        "workspace source files",
        "configs/rust/rustfmt.toml"
      ],
      "outputs": [
        "format validation status",
        "fmt stderr log"
      ],
      "commands": [
        "cargo fmt --locked --all -- --check --config-path configs/rust/rustfmt.toml"
      ],
      "reports": [
        "artifacts/lint/rustfmt-check.json"
      ],
      "suite_membership": [
        "checks"
      ],
      "severity": "blocker",
      "stage": "local",
      "runtime_cost": "low",
      "determinism": "strict",
      "since_version": "0.1.0",
      "tags": [
        "rust",
        "format"
      ]
    },
    {
      "check_id": "CHECK-RUST-CLIPPY-001",
