{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schemas/governance/checks-output.schema.json",
  "title": "Checks Run Output",
  "type": "object",
  "required": ["schema_version", "summary", "results"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "skipped", "errors"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "skipped": {"type": "integer", "minimum": 0},
        "errors": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "domain",
          "severity",
          "mode",
          "duration_ms",
          "status",
          "evidence_paths",
          "hint"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "domain": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["blocker", "major", "minor", "info"]},
          "mode": {"type": "string", "enum": ["static", "effect", "integration", "pure"]},
          "duration_ms": {"type": "integer", "minimum": 0},
          "status": {"type": "string", "enum": ["PASS", "FAIL", "SKIP", "ERROR"]},
          "evidence_paths": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "hint": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
