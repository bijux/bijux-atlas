{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/observability/log-field-inventory.schema.json",
  "title": "Audit Log Field Inventory Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "summary",
    "rows"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "errors"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "classification",
          "observed_in_code"
        ],
        "properties": {
          "field": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "classification": {
            "type": "string",
            "enum": [
              "safe",
              "sensitive",
              "unknown"
            ]
          },
          "observed_in_code": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
