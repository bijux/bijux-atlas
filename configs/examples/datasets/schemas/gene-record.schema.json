{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "atlas-gene-record",
  "type": "object",
  "required": ["gene_id", "symbol", "chromosome", "biotype", "length_bp"],
  "properties": {
    "gene_id": {"type": "string"},
    "symbol": {"type": "string"},
    "chromosome": {"type": "string"},
    "biotype": {"type": "string"},
    "length_bp": {"type": "integer", "minimum": 1},
    "gc_content": {"type": "number", "minimum": 0, "maximum": 1},
    "description": {"type": "string"}
  },
  "additionalProperties": true
}
