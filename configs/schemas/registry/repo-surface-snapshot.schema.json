{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/configs/registry/repo-surface-snapshot.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "make_public_targets",
    "docs_indexes",
    "config_groups"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "make_public_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "docs_indexes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "config_groups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
