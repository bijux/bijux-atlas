{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Institutional Packet Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_by",
    "evidence_root",
    "required_minimum",
    "items",
    "contracts"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "evidence_root": {
      "type": "string",
      "minLength": 1
    },
    "required_minimum": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "REL-PACK-001"
      ],
      "properties": {
        "REL-PACK-001": {
          "type": "boolean"
        }
      }
    }
  }
}
