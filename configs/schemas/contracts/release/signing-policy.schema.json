{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/release/signing-policy.schema.json",
  "title": "Release Signing Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mechanism",
    "key_custody_model",
    "verification",
    "signed_items"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "mode",
        "rationale"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "key_custody_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "storage",
        "rotation_expectation"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "storage": {
          "type": "string",
          "minLength": 1
        },
        "rotation_expectation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "airgap_supported",
        "notes"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "airgap_supported": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "signed_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "kind",
          "required"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
