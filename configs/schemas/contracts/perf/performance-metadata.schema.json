{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Performance Metadata",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "baseline_profile",
    "candidate_profile",
    "dataset_tier",
    "source_artifacts",
    "generated_by"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "kind": {"type": "string", "const": "performance_metadata_v1"},
    "baseline_profile": {"type": "string", "minLength": 1},
    "candidate_profile": {"type": "string", "minLength": 1},
    "dataset_tier": {"type": "string", "enum": ["small", "medium", "large", "x_large"]},
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "generated_by": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
