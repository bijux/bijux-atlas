{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Benchmark Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "benchmark_id", "dataset_id", "metrics"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latency_p50_ms",
        "latency_p95_ms",
        "latency_p99_ms",
        "throughput_ops_per_sec"
      ],
      "properties": {
        "latency_p50_ms": {"type": "number", "minimum": 0},
        "latency_p95_ms": {"type": "number", "minimum": 0},
        "latency_p99_ms": {"type": "number", "minimum": 0},
        "throughput_ops_per_sec": {"type": "number", "exclusiveMinimum": 0}
      }
    }
  }
}
