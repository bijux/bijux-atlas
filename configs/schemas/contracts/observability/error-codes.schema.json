{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "codes"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "http_status"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "http_status": {
            "type": "integer",
            "minimum": 400,
            "maximum": 599
          }
        }
      }
    }
  }
}
