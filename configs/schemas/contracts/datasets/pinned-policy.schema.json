{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pinned Dataset Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profiles"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "offline"
      ],
      "properties": {
        "offline": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_dataset_ids"
          ],
          "properties": {
            "required_dataset_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[0-9]+/[a-z_]+/[A-Za-z0-9._-]+$"
              }
            }
          }
        }
      }
    }
  }
}
