{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ingest Dry Run Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_id",
    "source_dir",
    "steps",
    "expected_outputs",
    "contracts"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^[0-9]+/[a-z_]+/[A-Za-z0-9._-]+$"
    },
    "source_dir": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "INGEST-001"
      ],
      "properties": {
        "INGEST-001": {
          "type": "boolean"
        }
      }
    }
  }
}
