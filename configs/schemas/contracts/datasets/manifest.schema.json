{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "allowed_licenses",
    "datasets"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "allowed_licenses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "version",
          "source",
          "license",
          "checksum",
          "size",
          "schema_version"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]+/[a-z_]+/[A-Za-z0-9._-]+$"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "checksum": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "schema_version": {
            "type": "integer",
            "const": 1
          }
        }
      }
    }
  }
}
