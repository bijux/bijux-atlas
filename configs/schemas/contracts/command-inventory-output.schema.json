{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/contracts/command-inventory-output.schema.json",
  "title": "Command Inventory Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "name", "count", "commands"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "command_inventory"
    },
    "name": {
      "type": "string",
      "const": "bijux-dev-atlas"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "purpose",
          "effects",
          "inputs",
          "outputs",
          "report_ids",
          "hidden"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["group", "leaf"] },
          "purpose": { "type": "string", "minLength": 1 },
          "effects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "report_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "hidden": { "type": "boolean" },
          "subcommands": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
