{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schemas/security/resources.schema.json",
  "title": "Security Resources Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "resources"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
