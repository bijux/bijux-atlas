{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/compliance-matrix.schema.json",
  "title": "Security Compliance Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mappings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "evidence"
        ],
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^CTRL-[A-Z0-9-]+$"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
