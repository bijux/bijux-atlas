{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/secrets.schema.json",
  "title": "Declared Secret Inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "secrets"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "secrets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "storage_method"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "storage_method": {
            "type": "string",
            "enum": [
              "env",
              "file",
              "k8s_secret"
            ]
          }
        }
      }
    }
  }
}
