{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/threats.schema.json",
  "title": "Security Threat Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "threats"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "threats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "title",
          "severity",
          "likelihood",
          "affected_component",
          "mitigations",
          "residual_risk"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SEC-THREAT-[A-Z0-9-]+$"
          },
          "category": {
            "type": "string",
            "enum": [
              "spoofing",
              "tampering",
              "repudiation",
              "information-disclosure",
              "denial-of-service",
              "elevation-of-privilege"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "likelihood": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "affected_component": {
            "type": "string",
            "minLength": 1
          },
          "mitigations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^MIT-[A-Z0-9-]+$"
            }
          },
          "residual_risk": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
