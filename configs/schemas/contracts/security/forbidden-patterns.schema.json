{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/security/forbidden-patterns.schema.json",
  "title": "Forbidden Secret Scan Patterns",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "patterns"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "literal"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "literal": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
