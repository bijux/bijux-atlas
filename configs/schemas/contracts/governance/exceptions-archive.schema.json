{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/governance/repository/exceptions-archive.schema.json",
  "title": "Governance Exceptions Archive",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "archived_exceptions"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "archived_exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scope",
          "severity",
          "reason",
          "owner",
          "created_at",
          "expires_at",
          "mitigation",
          "tracking_link",
          "risk_accepted_by",
          "verification_plan",
          "archived_at",
          "content_sha256"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^EXC-[A-Z0-9-]+$"
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "id"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["contract", "check"]
              },
              "id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "reason": {
            "type": "string",
            "enum": ["compatibility", "third-party", "incident-response"]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "expires_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          },
          "tracking_link": {
            "type": "string",
            "format": "uri"
          },
          "risk_accepted_by": {
            "type": "string",
            "minLength": 1
          },
          "verification_plan": {
            "type": "string",
            "minLength": 1
          },
          "archived_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "content_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
