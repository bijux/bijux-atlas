{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/governance/repository/check-groups.schema.json",
  "title": "Check Groups",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "group_set_id", "owner", "groups"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "group_set_id": { "type": "string", "const": "check-groups" },
    "owner": { "type": "string", "minLength": 1 },
    "groups": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
