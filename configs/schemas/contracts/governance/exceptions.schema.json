{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/governance/repository/exceptions.schema.json",
  "title": "Governance Exceptions Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy", "reason_taxonomy", "exceptions"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_days_by_severity", "warning_days", "allowed_tracking_domains", "no_exception_zones"],
      "properties": {
        "max_days_by_severity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "medium", "high"],
          "properties": {
            "low": { "type": "integer", "minimum": 1 },
            "medium": { "type": "integer", "minimum": 1 },
            "high": { "type": "integer", "minimum": 1 }
          }
        },
        "warning_days": {
          "type": "integer",
          "minimum": 1
        },
        "allowed_tracking_domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "no_exception_zones": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "reason_taxonomy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["compatibility", "third-party", "incident-response"]
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scope",
          "severity",
          "reason",
          "owner",
          "created_at",
          "expires_at",
          "mitigation",
          "tracking_link",
          "risk_accepted_by",
          "verification_plan"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^EXC-[A-Z0-9-]+$"
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "id"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["contract", "check"]
              },
              "id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "reason": {
            "type": "string",
            "enum": ["compatibility", "third-party", "incident-response"]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "expires_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          },
          "tracking_link": {
            "type": "string",
            "format": "uri"
          },
          "risk_accepted_by": {
            "type": "string",
            "minLength": 1
          },
          "verification_plan": {
            "type": "string",
            "minLength": 1
          },
          "governance_approval": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
