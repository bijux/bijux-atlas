{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/contracts/reports/closure-index.schema.json",
  "title": "closure-index report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "version",
    "inputs",
    "summary",
    "evidence",
    "entries"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "closure-index"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "inputs": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    },
    "evidence": {
      "type": "object"
    },
    "entries": {
      "type": "array"
    }
  }
}
