{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "configs/schemas/contracts/real-data-runs.schema.json",
  "title": "Real Data Runs Catalog",
  "type": "object",
  "required": ["schema_version", "runs"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "runs": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "id",
          "run_label",
          "dataset",
          "dataset_size_tier",
          "ingest_mode",
          "expected_outputs",
          "input_provenance",
          "expected_query_set",
          "expected_artifacts",
          "expected_resource_profile",
          "expected_runtime_compatibility"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "run_label": {"type": "string", "minLength": 1},
          "dataset": {"type": "string", "minLength": 1},
          "dataset_size_tier": {"type": "string", "enum": ["tiny", "medium", "large-sample"]},
          "ingest_mode": {"type": "string", "minLength": 1},
          "expected_outputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "input_provenance": {
            "type": "object",
            "required": ["url", "retrieval_method", "license_note"],
            "properties": {
              "url": {"type": "string", "minLength": 1},
              "retrieval_method": {"type": "string", "minLength": 1},
              "license_note": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "expected_query_set": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "description"],
              "properties": {
                "name": {"type": "string", "minLength": 1},
                "description": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "expected_artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "expected_resource_profile": {
            "type": "object",
            "required": ["cpu_mem_class"],
            "properties": {
              "cpu_mem_class": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "expected_runtime_compatibility": {
            "type": "object",
            "required": ["min_version", "max_version"],
            "properties": {
              "min_version": {"type": "string", "minLength": 1},
              "max_version": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
