{
  "schema_version": 1,
  "policy_id": "ops.markdown.naming",
  "default_standard": "SNAKE_UPPER",
  "canonical_filenames": [
    "README.md",
    "INDEX.md",
    "CONTRACT.md",
    "OWNER.md",
    "REQUIRED_FILES.md"
  ],
  "exceptions": [
    "ops/_generated.example/control-plane.snapshot.md",
    "ops/schema/generated/schema-index.md",
    "ops/observe/drills/templates/incident-template.md"
  ],
  "rule": "Authored ops markdown files must use SNAKE_UPPER names unless in canonical_filenames or explicit exceptions."
}
