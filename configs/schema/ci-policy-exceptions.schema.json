{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schema_version", "exceptions"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_id",
          "workflow",
          "job",
          "step",
          "owner",
          "reason",
          "expires_on",
          "renewal_reference",
          "governance_tier"
        ],
        "properties": {
          "policy_id": {
            "type": "string"
          },
          "workflow": {
            "type": "string"
          },
          "job": {
            "type": "string"
          },
          "step": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "expires_on": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "renewal_reference": {
            "type": "string",
            "minLength": 1
          },
          "governance_tier": {
            "enum": ["temporary", "governance-approved"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
