{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "workflow",
          "job",
          "step",
          "owner",
          "reason",
          "expires_on",
          "renewal_reference"
        ],
        "properties": {
          "workflow": {
            "type": "string"
          },
          "job": {
            "type": "string"
          },
          "step": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "expires_on": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "renewal_reference": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
