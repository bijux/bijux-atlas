{
  "schema_version": 1,
  "forbidden_patterns": [
    "aws_access_key_prefix",
    "private_key_header",
    "credential_assignment",
    "auth_token_assignment"
  ],
  "applies_to": [
    "artifacts/tutorials/runs/*/evidence-bundle.json",
    "artifacts/tutorials/runs/*/logs/*"
  ],
  "rule": "Evidence and logs must not contain secrets or credentials."
}
