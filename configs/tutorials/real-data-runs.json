      "id": "rdr-001-genes-baseline",
      "run_label": "Genes Baseline Tiny",
      "dataset": "genes-baseline",
      "dataset_size_tier": "tiny",
      "ingest_mode": "full-rebuild",
      "expected_outputs": ["ingest-report", "dataset-summary"],
      "input_provenance": {
        "url": "https://example.org/datasets/genes-baseline.csv",
        "retrieval_method": "https-get",
        "license_note": "Public domain demonstration dataset"
      },
      "expected_query_set": [
        {"name": "gene_count_total", "description": "count all ingested genes"}
      ],
      "expected_artifacts": ["ingest-report.json", "dataset-summary.json"],
      "expected_resource_profile": {"cpu_mem_class": "small"},
      "expected_runtime_compatibility": {"min_version": "0.1.0", "max_version": "0.2.0"}
    },
