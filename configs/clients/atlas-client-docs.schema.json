{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["client", "python_sdk", "atlas_runtime", "api_surface", "docs_entries"],
  "properties": {
    "client": {"type": "string"},
    "python_sdk": {"type": "string"},
    "atlas_runtime": {"type": "string"},
    "api_surface": {"type": "string"},
    "docs_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "path"],
        "properties": {
          "title": {"type": "string"},
          "path": {"type": "string"}
        }
      }
    }
  }
}
