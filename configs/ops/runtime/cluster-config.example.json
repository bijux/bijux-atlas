{
  "schema_version": 1,
  "cluster_id": "atlas-prod-eu1",
  "topology_mode": "clustered_static",
  "discovery": {
    "strategy": "static_seed_list",
    "seed_nodes": [
      "http://atlas-node-1.internal:8080",
      "http://atlas-node-2.internal:8080"
    ]
  },
  "bootstrap": {
    "join_timeout_ms": 5000,
    "max_join_attempts": 5
  },
  "health": {
    "heartbeat_interval_ms": 1000,
    "node_timeout_ms": 5000,
    "required_role_quorum": {
      "ingest": 1,
      "query": 2
    }
  },
  "metadata_store": {
    "backend": "sqlite",
    "endpoint": "file:.atlas/cluster-metadata.db"
  },
  "compatibility": {
    "min_node_version": "1.0.0",
    "max_skew_major": 0
  }
}
