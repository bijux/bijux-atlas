#compdef bijux-dev-atlas

local -a commands
commands=(
  'api:API commands'
  'observe:observability commands'
  'load:load testing commands'
  'ops:operations commands'
  'audit:audit commands'
  'invariants:invariant commands'
  'drift:drift commands'
  'reproduce:reproducibility commands'
)

_arguments '1:command:->cmds' '*::arg:->args'

case $state in
  cmds)
    _describe 'command' commands
    ;;
esac
