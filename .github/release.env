# Unified release workflow configuration.

BIJUX_RELEASE_ENABLED=true
BIJUX_RELEASE_WAIT_FOR_CI_COMMAND=make gh-release-wait-for-ci
BIJUX_RELEASE_PLAN_COMMAND=make gh-release-plan-github
BIJUX_RELEASE_PREPARE_COMMAND=.github/scripts/prepare_release_github.sh
BIJUX_RELEASE_SETUP_RUST=true
BIJUX_RELEASE_RUST_TOOLCHAIN=1.86.0
BIJUX_RELEASE_FILES_MANIFEST=.github/release-github.files
BIJUX_RELEASE_NOTES_PATH=artifacts/github-release/release-notes.md
BIJUX_RELEASE_DELETE_EXISTING=false
BIJUX_RELEASE_FAIL_ON_UNMATCHED_FILES=true
BIJUX_RELEASE_GENERATE_RELEASE_NOTES=false
BIJUX_RELEASE_ARTIFACTS_ENABLED=false
BIJUX_CRATES_RELEASE_ENABLED=true
BIJUX_CRATES_RELEASE_WAIT_FOR_CI_COMMAND=make gh-release-wait-for-ci
BIJUX_CRATES_RELEASE_PLAN_COMMAND=make gh-release-plan-crates
BIJUX_CRATES_RELEASE_SETUP_RUST=true
BIJUX_CRATES_RELEASE_RUST_TOOLCHAIN=1.86.0
BIJUX_CRATES_RELEASE_VERIFY_TOKEN_COMMAND=make gh-release-require-cargo-token
BIJUX_CRATES_RELEASE_PUBLISH_SKIP_EXISTING=true
BIJUX_CRATES_RELEASE_PUBLISH_COMMAND=make publish-rs RUST_PUBLISH_DRY_RUN=0 RUST_PUBLISH_SKIP_EXISTING=1 RUST_PUBLISH_PACKAGES="${PACKAGES}"
BIJUX_GHCR_RELEASE_ENABLED=false
BIJUX_PYPI_ENABLED=false
