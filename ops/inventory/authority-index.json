{
  "schema_version": 1,
  "authority_hierarchy": [
    "ops/inventory",
    "ops/schema",
    "docs"
  ],
  "authoritative_files": [
    {
      "path": "ops/CONTRACT.md",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_tree_contract"
    },
    {
      "path": "ops/ERRORS.md",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_tree_contract"
    },
    {
      "path": "ops/INDEX.md",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_surface_inventory"
    },
    {
      "path": "ops/README.md",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_tree_contract"
    },
    {
      "path": "ops/SSOT.md",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_tree_contract"
    },
    {
      "path": "ops/inventory/authoritative-file-list.json",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_inventory_contract_integrity"
    },
    {
      "path": "ops/inventory/authority-index.json",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_inventory_contract_integrity"
    },
    {
      "path": "ops/inventory/contracts-map.json",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_inventory_contract_integrity"
    },
    {
      "path": "ops/inventory/contracts.json",
      "role": "generated",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_inventory_contract_integrity",
      "producer": "manual+registry-sync",
      "derived_from": "ops/inventory/contracts-map.json"
    },
    {
      "path": "ops/inventory/gates.json",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_manifest_integrity"
    },
    {
      "path": "ops/inventory/generated-committed-mirror.json",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_generated_readonly_markers"
    },
    {
      "path": "ops/inventory/surfaces.json",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_surface_manifest"
    },
    {
      "path": "ops/inventory/toolchain.json",
      "role": "authoritative",
      "owner": "bijux-atlas-operations",
      "consumer": "checks_ops_inventory_contract_integrity"
    }
  ],
  "ignored_prefixes": [
    "ops/_generated/",
    "ops/_generated.example/",
    "ops/api/",
    "ops/audit/",
    "ops/cli/",
    "ops/datasets/",
    "ops/docker/",
