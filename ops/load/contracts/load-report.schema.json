{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas load report schema",
  "type": "object",
  "required": ["schema_version", "kind", "suite", "run_id", "metrics", "thresholds", "violations"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "kind": {"type": "string", "const": "ops_load_report_v1"},
    "suite": {"type": "string"},
    "run_id": {"type": "string"},
    "metrics": {
      "type": "object",
      "required": ["p95_ms", "p99_ms", "error_rate"],
      "properties": {
        "p95_ms": {"type": "number", "minimum": 0},
        "p99_ms": {"type": "number", "minimum": 0},
        "error_rate": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": true
    },
    "thresholds": {
      "type": "object",
      "required": ["p95_ms_max", "p99_ms_max", "error_rate_max"],
      "properties": {
        "p95_ms_max": {"type": "number", "minimum": 0},
        "p99_ms_max": {"type": "number", "minimum": 0},
        "error_rate_max": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": true
    },
    "violations": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
