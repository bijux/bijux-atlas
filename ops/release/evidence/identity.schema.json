{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/release/evidence/identity.schema.json",
  "title": "Release Evidence Identity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "git_sha",
    "governance_version"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "governance_version": {
      "type": "string",
      "minLength": 1
    }
  }
}
