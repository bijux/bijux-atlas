    {"title": "CPU Utilization", "type": "timeseries", "targets": [{"expr": "atlas_runtime_cpu_utilization_percent"}]},
    {"title": "Thread Count", "type": "timeseries", "targets": [{"expr": "atlas_runtime_thread_count"}]},
    {"title": "Open File Descriptors", "type": "timeseries", "targets": [{"expr": "atlas_runtime_open_file_descriptors"}]}
  ]
