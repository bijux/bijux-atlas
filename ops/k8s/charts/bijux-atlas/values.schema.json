{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bijux-atlas chart values",
  "description": "Strict allowlist for supported Helm values. Unknown top-level keys are rejected so chart profiles fail fast when they drift from the published contract.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "k8sQuantity": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+)?(?:[eEinumkKMGTP]+i?)?$"
    },
    "dnsLabel": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "dnsName": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*$"
    },
    "cidr": {
      "type": "string",
      "pattern": "^(?:\\d{1,3}\\.){3}\\d{1,3}/\\d{1,2}$"
    },
    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(?:ms|s|m|h)$"
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowPrivilegeEscalation": {
          "const": false
        },
        "readOnlyRootFilesystem": {
          "const": true
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "drop": {
              "const": [
                "ALL"
              ]
            }
          },
          "required": [
            "drop"
          ]
        }
      },
      "required": [
        "allowPrivilegeEscalation",
        "readOnlyRootFilesystem",
        "capabilities"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "cache": {
            "type": "object",
            "properties": {
              "cachedOnlyMode": {
                "const": true
              }
            },
            "required": [
              "cachedOnlyMode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "cache": {
            "type": "object",
            "properties": {
              "readinessRequiresCatalog": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "description": "Exactly one image selector must be set: use a digest for immutable deploys or a tag for mutable/dev flows, never both.",
      "oneOf": [
        {
          "properties": {
            "image": {
              "type": "object",
              "properties": {
                "digest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "tag": {
                  "type": "string",
                  "maxLength": 0
                }
              },
              "required": [
                "digest",
                "tag"
              ]
            }
          }
        },
        {
          "properties": {
            "image": {
              "type": "object",
              "properties": {
                "digest": {
                  "type": "string",
                  "maxLength": 0
                },
                "tag": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^(?!latest$)[A-Za-z0-9_][A-Za-z0-9._-]{0,127}$"
                }
              },
              "required": [
                "digest",
                "tag"
              ]
            }
          }
        }
      ]
    }
  ],
  "properties": {
    "affinity": {
      "type": "object"
    },
    "alertRules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "runbookUrlBase": {
          "type": "string",
          "pattern": "^https?://.+"
        }
      },
      "required": [
        "enabled",
        "runbookUrlBase"
      ]
    },
    "cache": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cachedOnlyMode": {
          "type": "boolean"
        },
        "initPrewarm": {
          "type": "object",
          "additionalProperties": true
        },
        "pinnedDatasets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readinessRequiresCatalog": {
          "type": "boolean"
        }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backoffBaseMs": {
          "type": "integer",
          "minimum": 0
        },
        "breakerFailureThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "breakerOpenMs": {
          "type": "integer",
          "minimum": 0
        },
        "endpoint": {
          "type": "string",
          "pattern": "^(|https?://.+)$"
        },
        "etagEnabled": {
          "type": "boolean"
        }
      },
      "required": [
        "endpoint",
        "etagEnabled",
        "backoffBaseMs",
        "breakerFailureThreshold",
        "breakerOpenMs"
      ]
    },
    "catalogPublishJob": {
      "type": "object"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error"
          ]
        }
      }
    },
    "containerSecurityContext": {
      "$ref": "#/$defs/containerSecurityContext"
    },
    "datasetWarmupJob": {
      "type": "object"
    },
    "env": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Z0-9_]+$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "extraEnv": {
      "type": "array"
    },
    "hpa": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "behavior": {
          "type": "object"
        },
        "cpu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "targetAverageUtilization": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "cpuUtilization": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "enabled": {
          "type": "boolean"
        },
        "heavyInflightAverageValue": {
          "type": "string",
          "minLength": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1,
          "description": "Must be greater than or equal to hpa.minReplicas. Portable Helm JSON Schema cannot compare sibling integers, so the chart enforces this relation during template rendering."
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "targetAverageUtilization": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "p95LatencySeconds": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "cpuUtilization",
        "p95LatencySeconds",
        "heavyInflightAverageValue",
        "behavior"
      ]
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "description": "Set exactly one of image.digest or image.tag. Digest is preferred for immutable production rollouts.",
      "properties": {
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "repository": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "@"
          }
        },
        "tag": {
          "type": "string",
          "pattern": "^$|^(?!latest$)[A-Za-z0-9_][A-Za-z0-9._-]{0,127}$"
        }
      },
      "required": [
        "repository",
        "tag",
        "digest",
        "pullPolicy"
      ]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "className": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string",
          "pattern": "^$|^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*$"
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": {
                "$ref": "#/$defs/dnsName"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": {
                      "type": "string",
                      "pattern": "^/"
                    }
                  },
                  "required": [
                    "path"
                  ]
                }
              }
            },
            "required": [
              "host",
              "paths"
            ]
          }
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "hosts": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/dnsName"
                }
              },
              "secretName": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "secretName"
            ]
          }
        }
      },
      "required": [
        "enabled",
        "className",
        "host",
        "path"
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "customMetrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "requiredPodAnnotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "properties": {
                "prometheus.io/path": {
                  "type": "string",
                  "minLength": 1
                },
                "prometheus.io/scrape": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "prometheus.io/scrape",
                "prometheus.io/path"
              ]
            }
          },
          "required": [
            "enabled",
            "requiredPodAnnotations"
          ]
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "interval": {
              "$ref": "#/$defs/duration"
            },
            "labels": {
              "type": "object"
            },
            "scrapeTimeout": {
              "$ref": "#/$defs/duration"
            }
          },
          "required": [
            "enabled",
            "interval",
            "scrapeTimeout",
            "labels"
          ]
        }
      },
      "required": [
        "enabled",
        "customMetrics",
        "serviceMonitor"
      ]
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowDns": {
          "type": "boolean"
        },
        "allowedEgressCIDRs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cidr"
          }
        },
        "egress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowCidrs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/cidr"
              }
            },
            "allowDns": {
              "type": "boolean"
            },
            "allowNamespaces": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/dnsLabel"
              }
            },
            "mode": {
              "type": "string",
              "enum": [
                "disabled",
                "internet-only",
                "cluster-aware",
                "custom"
              ]
            }
          }
        },
        "enabled": {
          "type": "boolean"
        },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowNamespaces": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/dnsLabel"
              }
            },
            "mode": {
              "type": "string",
              "enum": [
                "disabled",
                "same-namespace",
                "selected",
                "custom"
              ]
            }
          }
        }
      },
      "required": [
        "enabled",
        "allowDns",
        "allowedEgressCIDRs"
      ]
    },
    "nodeLocalSsdProfile": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "pdb": {
      "type": "object"
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fsGroup": {
          "type": "integer",
          "minimum": 1
        },
        "runAsGroup": {
          "type": "integer",
          "minimum": 1
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "runAsNonRoot",
        "runAsUser"
      ]
    },
    "priorityClassName": {
      "type": "string"
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "liveness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 0
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "initialDelaySeconds",
            "periodSeconds"
          ]
        },
        "readiness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 0
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "initialDelaySeconds",
            "periodSeconds"
          ]
        }
      },
      "required": [
        "liveness",
        "readiness"
      ]
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string",
              "pattern": "^\\d+m?$"
            },
            "ephemeral-storage": {
              "$ref": "#/$defs/k8sQuantity"
            },
            "memory": {
              "$ref": "#/$defs/k8sQuantity"
            }
          },
          "required": [
            "cpu",
            "memory"
          ]
        },
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string",
              "pattern": "^\\d+m?$"
            },
            "ephemeral-storage": {
              "$ref": "#/$defs/k8sQuantity"
            },
            "memory": {
              "$ref": "#/$defs/k8sQuantity"
            }
          },
          "required": [
            "cpu",
            "memory"
          ]
        }
      },
      "required": [
        "requests",
        "limits"
      ]
    },
    "rollout": {
      "type": "object"
    },
    "securityContext": {
      "$ref": "#/$defs/containerSecurityContext",
      "description": "Deprecated alias for containerSecurityContext. Prefer containerSecurityContext for new values files."
    },
    "sequenceRateLimits": {
      "type": "object"
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "cachedOnlyMode": {
          "type": "boolean"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "configSchemaVersion": {
          "type": "string",
          "minLength": 1
        },
        "enableDebugDatasets": {
          "type": "boolean"
        },
        "enableExemplars": {
          "type": "boolean"
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "maxBodyBytes": {
          "type": "integer",
          "minimum": 0
        },
        "maxSequenceBases": {
          "type": "integer",
          "minimum": 0
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "readOnlyFsMode": {
          "type": "boolean"
        },
        "readinessProbePath": {
          "type": "string",
          "pattern": "^/"
        },
        "readinessRequiresCatalog": {
          "type": "boolean"
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "responseMaxBytes": {
          "type": "integer",
          "minimum": 0
        },
        "requestTimeoutSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "sequenceApiKeyRequiredBases": {
          "type": "integer",
          "minimum": 0
        },
        "sequenceTtlMs": {
          "type": "integer",
          "minimum": 0
        },
        "shutdownDrainMs": {
          "type": "integer",
          "minimum": 0
        },
        "shutdownGraceSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "slowQueryThresholdMs": {
          "type": "integer",
          "minimum": 0
        },
        "sqlTimeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "startupProbePath": {
          "type": "string",
          "pattern": "^/"
        }
      },
      "required": [
        "command",
        "configSchemaVersion",
        "startupProbePath",
        "readinessProbePath",
        "requestTimeoutMs",
        "sqlTimeoutMs",
        "responseMaxBytes",
        "maxBodyBytes",
        "slowQueryThresholdMs",
        "enableDebugDatasets",
        "enableExemplars",
        "cachedOnlyMode",
        "readOnlyFsMode",
        "shutdownDrainMs",
        "readinessRequiresCatalog",
        "maxSequenceBases",
        "sequenceApiKeyRequiredBases",
        "sequenceTtlMs"
      ]
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "$ref": "#/$defs/stringMap"
        },
        "nodePort": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 65535
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        }
      },
      "required": [
        "type",
        "port"
      ]
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": false,
      "description": "Deprecated alias for metrics.serviceMonitor. Prefer metrics.serviceMonitor for new values files.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "$ref": "#/$defs/duration"
        },
        "labels": {
          "type": "object"
        },
        "scrapeTimeout": {
          "$ref": "#/$defs/duration"
        }
      },
      "required": [
        "enabled",
        "interval",
        "scrapeTimeout",
        "labels"
      ]
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "credentialsSecretName": {
          "type": "string"
        },
        "endpoint": {
          "type": "string",
          "pattern": "^(|https?://.+)$"
        },
        "manageCredentialsSecret": {
          "type": "boolean"
        },
        "s3PresignedBaseUrl": {
          "type": "string",
          "pattern": "^(|https?://.+)$"
        }
      },
      "required": [
        "endpoint",
        "s3PresignedBaseUrl",
        "credentialsSecretName",
        "manageCredentialsSecret"
      ]
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "tolerations": {
      "type": "array"
    }
  }
}
