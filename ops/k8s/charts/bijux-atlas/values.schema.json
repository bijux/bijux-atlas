{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "image": {
            "properties": {
              "digest": {
                "minLength": 1
              },
              "tag": {
                "minLength": 1
              }
            },
            "required": [
              "digest",
              "tag"
            ],
            "type": "object"
          }
        }
      },
      "then": {
        "properties": {
          "image": {
            "properties": {
              "tag": {
                "maxLength": 0
              }
            },
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cache": {
            "properties": {
              "initPrewarm": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                },
                "type": "object"
              }
            },
            "type": "object"
          }
        }
      },
      "then": {
        "properties": {
          "cache": {
            "properties": {
              "pinnedDatasets": {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "minItems": 1,
                "type": "array"
              }
            },
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "alertRules": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "type": "object"
          }
        }
      },
      "then": {
        "properties": {
          "serviceMonitor": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "server": {
            "properties": {
              "cachedOnlyMode": {
                "const": true
              }
            },
            "type": "object"
          }
        }
      },
      "then": {
        "properties": {
          "server": {
            "properties": {
              "readinessRequiresCatalog": {
                "const": false
              }
            },
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "hpa": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "type": "object"
          }
        }
      },
      "then": {
        "properties": {
          "hpa": {
            "properties": {
              "minReplicas": {
                "minimum": 1,
                "type": "integer"
              },
              "maxReplicas": {
                "minimum": 1,
                "type": "integer"
              },
              "cpuUtilization": {
                "maximum": 100,
                "minimum": 1,
                "type": "integer"
              }
            },
            "type": "object"
          },
          "metrics": {
            "properties": {
              "customMetrics": {
                "properties": {
                  "enabled": {
                    "const": true
                  },
                  "requiredPodAnnotations": {
                    "properties": {
                      "prometheus.io/path": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "prometheus.io/scrape": {
                        "minLength": 1,
                        "type": "string"
                      }
                    },
                    "required": [
                      "prometheus.io/scrape",
                      "prometheus.io/path"
                    ],
                    "type": "object"
                  }
                },
                "type": "object"
              }
            },
            "type": "object"
          },
          "serviceMonitor": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "type": "object"
          }
        }
      }
    }
  ],
  "properties": {
    "affinity": {
      "description": "Chart values key `affinity` from SSOT contract."
    },
    "alertRules": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "runbookUrlBase": {
          "pattern": "^https?://.+",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "runbookUrlBase"
      ],
      "type": "object"
    },
    "cache": {
      "description": "Chart values key `cache` from SSOT contract."
    },
    "catalog": {
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "pattern": "^(|https?://.+)$",
          "type": "string"
        },
        "etagEnabled": {
          "type": "boolean"
        },
        "backoffBaseMs": {
          "minimum": 0,
          "type": "integer"
        },
        "breakerFailureThreshold": {
          "minimum": 1,
          "type": "integer"
        },
        "breakerOpenMs": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "endpoint",
        "etagEnabled",
        "backoffBaseMs",
        "breakerFailureThreshold",
        "breakerOpenMs"
      ],
      "type": "object"
    },
    "catalogPublishJob": {
      "description": "Chart values key `catalogPublishJob` from SSOT contract."
    },
    "datasetWarmupJob": {
      "description": "Chart values key `datasetWarmupJob` from SSOT contract."
    },
    "extraEnv": {
      "description": "Chart values key `extraEnv` from SSOT contract."
    },
    "hpa": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "minimum": 1,
          "type": "integer"
        },
        "maxReplicas": {
          "minimum": 1,
          "type": "integer"
        },
        "cpuUtilization": {
          "maximum": 100,
          "minimum": 1,
          "type": "integer"
        },
        "p95LatencySeconds": {
          "minLength": 1,
          "type": "string"
        },
        "heavyInflightAverageValue": {
          "minLength": 1,
          "type": "string"
        },
        "behavior": {
          "type": "object"
        }
      },
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "cpuUtilization",
        "p95LatencySeconds",
        "heavyInflightAverageValue",
        "behavior"
      ],
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^(|sha256:[a-f0-9]{64})$",
          "type": "string"
        },
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "minLength": 1,
          "not": {
            "pattern": "@"
          },
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "required": [
        "repository",
        "tag",
        "digest",
        "pullPolicy"
      ],
      "type": "object"
    },
    "ingress": {
      "description": "Chart values key `ingress` from SSOT contract."
    },
    "metrics": {
      "additionalProperties": false,
      "properties": {
        "customMetrics": {
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "requiredPodAnnotations": {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {
                "prometheus.io/path": {
                  "minLength": 1,
                  "type": "string"
                },
                "prometheus.io/scrape": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "prometheus.io/scrape",
                "prometheus.io/path"
              ],
              "type": "object"
            }
          },
          "required": [
            "enabled",
            "requiredPodAnnotations"
          ],
          "type": "object"
        }
      },
      "required": [
        "customMetrics"
      ],
      "type": "object"
    },
    "networkPolicy": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "allowDns": {
          "type": "boolean"
        },
        "allowedEgressCIDRs": {
          "items": {
            "pattern": "^[^\\s]+$",
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "enabled",
        "allowDns",
        "allowedEgressCIDRs"
      ],
      "type": "object"
    },
    "nodeLocalSsdProfile": {
      "description": "Chart values key `nodeLocalSsdProfile` from SSOT contract."
    },
    "nodeSelector": {
      "description": "Chart values key `nodeSelector` from SSOT contract."
    },
    "pdb": {
      "description": "Chart values key `pdb` from SSOT contract."
    },
    "podSecurityContext": {
      "description": "Chart values key `podSecurityContext` from SSOT contract."
    },
    "priorityClassName": {
      "description": "Chart values key `priorityClassName` from SSOT contract."
    },
    "replicaCount": {
      "description": "Chart values key `replicaCount` from SSOT contract."
    },
    "resources": {
      "description": "Chart values key `resources` from SSOT contract."
    },
    "rollout": {
      "description": "Chart values key `rollout` from SSOT contract."
    },
    "securityContext": {
      "description": "Chart values key `securityContext` from SSOT contract."
    },
    "sequenceRateLimits": {
      "description": "Chart values key `sequenceRateLimits` from SSOT contract."
    },
    "server": {
      "description": "Chart values key `server` from SSOT contract."
    },
    "service": {
      "description": "Chart values key `service` from SSOT contract."
    },
    "serviceMonitor": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "minLength": 1,
          "type": "string"
        },
        "scrapeTimeout": {
          "minLength": 1,
          "type": "string"
