{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops/schema/meta/compatibility-lock.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "targets"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["example_path", "schema_path", "required_fields"],
        "properties": {
          "example_path": {
            "type": "string",
            "minLength": 1
          },
          "schema_path": {
            "type": "string",
            "minLength": 1
          },
          "required_fields": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
