{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops/schema/meta/schema-index.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source", "generated_by", "files"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
