{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/drills/drills.schema.json",
  "title": "Institutional Drill Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "drills"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "drills": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "expected_outcome",
          "verification_steps"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "expected_outcome": {
            "type": "string",
            "minLength": 1
          },
          "verification_steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
