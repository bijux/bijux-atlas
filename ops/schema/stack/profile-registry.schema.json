{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops/schema/stack/profile-registry.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "profiles"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "class",
          "safety_level",
          "required_tools",
          "allowed_namespaces",
          "required_services",
          "optional_components",
          "doc_link",
          "config_source_paths"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "class": {
            "type": "string",
            "enum": [
              "dev",
              "stage",
              "prod"
            ]
          },
          "safety_level": {
            "type": "string",
            "minLength": 1
          },
          "required_tools": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowed_namespaces": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_services": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "optional_components": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "doc_link": {
            "type": "string",
            "minLength": 1
          },
          "config_source_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
