{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops/schema/stack/profile-intent.schema.json",
  "type": "object",
  "required": ["schema_version", "profiles"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "intended_usage", "allowed_effects", "required_dependencies"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "intended_usage": {
            "type": "string",
            "minLength": 1
          },
          "allowed_effects": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
