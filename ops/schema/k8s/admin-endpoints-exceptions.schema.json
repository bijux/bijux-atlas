{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schemas/k8s/admin-endpoints-exceptions.schema.json",
  "title": "Admin Endpoints Exceptions",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "exceptions"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profile", "owner", "expiresOn"],
        "properties": {
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "expiresOn": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    }
  }
}
