{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/k8s/ops-upgrade.schema.json",
  "title": "Ops Upgrade Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "cluster",
    "namespace",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "cluster": {
      "type": "string",
      "const": "kind"
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "details": {
      "type": "object"
    }
  }
}
