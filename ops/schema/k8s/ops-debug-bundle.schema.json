{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/k8s/ops-debug-bundle.schema.json",
  "title": "Ops Debug Bundle Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cluster",
    "namespace",
    "category",
    "status",
    "files"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "cluster": {
      "type": "string",
      "const": "kind"
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "logs",
        "describe",
        "events",
        "resources"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
