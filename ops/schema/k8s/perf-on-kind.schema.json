{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Performance On Kind Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "kind_status",
    "load_report_path",
    "contracts"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "kind_status": {
      "type": "string",
      "enum": [
        "reachable",
        "unreachable"
      ]
    },
    "load_report_path": {
      "type": "string",
      "minLength": 1
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "PERF-KIND-001"
      ],
      "properties": {
        "PERF-KIND-001": {
          "type": "boolean"
        }
      }
    }
  }
}
