{
  "$id": "ops/schema/k8s/perf-on-kind.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contracts": {
      "additionalProperties": false,
      "properties": {
        "PERF-KIND-001": {
          "type": "boolean"
        }
      },
      "required": [
        "PERF-KIND-001"
      ],
      "type": "object"
    },
    "kind_status": {
      "enum": [
        "reachable",
        "unreachable"
      ],
      "type": "string"
    },
    "load_report_path": {
      "minLength": 1,
      "type": "string"
    },
    "profile": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "profile",
    "kind_status",
    "load_report_path",
    "contracts"
  ],
  "title": "Performance On Kind Report",
  "type": "object"
}
