{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/ops/report/ops-evidence-bundle.schema.json",
  "title": "Ops Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "install_evidence",
    "render_evidence",
    "validate_evidence",
    "install_matrix_report",
    "render_matrix_report",
    "schema_coverage_report",
    "network_policy_coverage_report",
    "rbac_coverage_report",
    "inventory_snapshot",
    "tool_versions",
    "redaction_secret_keys"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "kind": { "type": "string", "const": "ops_evidence_bundle" },
    "run_id": { "type": "string", "minLength": 1 },
    "install_evidence": { "$ref": "#/$defs/pathSha" },
    "render_evidence": { "$ref": "#/$defs/pathSha" },
    "validate_evidence": { "$ref": "#/$defs/pathSha" },
    "install_matrix_report": { "$ref": "#/$defs/pathSha" },
    "render_matrix_report": { "$ref": "#/$defs/pathSha" },
    "schema_coverage_report": { "$ref": "#/$defs/pathSha" },
    "network_policy_coverage_report": { "$ref": "#/$defs/pathSha" },
    "rbac_coverage_report": { "$ref": "#/$defs/pathSha" },
    "inventory_snapshot": { "$ref": "#/$defs/pathSha" },
    "tool_versions": { "$ref": "#/$defs/pathSha" },
    "redaction_secret_keys": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "pathSha": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
