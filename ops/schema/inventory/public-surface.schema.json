{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entrypoints", "commands", "core_targets"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "core_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "schema_version": 1,
  "owner": "bijux-atlas-operations",
  "$id": "ops/schema/inventory/public-surface.schema.json"
}
