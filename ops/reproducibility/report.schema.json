{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops/reproducibility/report.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "kind": { "type": "string" },
    "status": { "enum": ["ok", "failed"] },
    "environment": { "type": "object" },
    "scenarios": { "type": "array" },
    "release_manifest_artifact_count": { "type": "integer", "minimum": 0 }
  }
}
