{
  "schema_version": 1,
  "registry_id": "governance-enforcement-rules",
  "rules": [
    {
      "id": "GOV-RULE-001",
      "title": "required files must exist",
      "severity": "high",
      "rule_type": "required_files_exist",
      "paths": [
        "README.md",
        "Cargo.toml",
        "configs/sources/governance/governance/governance.json"
      ],
      "classification": "repository"
    },
    {
      "id": "GOV-RULE-002",
      "title": "prohibited files must not exist",
      "severity": "medium",
      "rule_type": "prohibited_files_absent",
      "paths": [
        "tmp/governance-dump.json",
        "artifacts/tmp/governance-debug.log"
      ],
      "classification": "repository"
    },
    {
      "id": "GOV-RULE-003",
      "title": "repo layout must match contract",
      "severity": "high",
      "rule_type": "repo_layout_contract",
      "paths": [
        "configs/sources/governance/governance/enforcement/repo-layout-contract.json"
      ],
      "classification": "repository"
    },
    {
      "id": "GOV-RULE-004",
      "title": "docs front matter completeness",
      "severity": "medium",
      "rule_type": "docs_front_matter_complete",
      "paths": [
        "docs/operations"
      ],
      "classification": "documentation"
    },
    {
      "id": "GOV-RULE-005",
      "title": "contract registry completeness",
      "severity": "high",
      "rule_type": "contract_registry_complete",
      "paths": [
        "configs/sources/governance/governance/contracts.registry.json"
      ],
      "classification": "registry"
    },
    {
      "id": "GOV-RULE-006",
      "title": "checks registry completeness",
      "severity": "high",
      "rule_type": "checks_registry_complete",
      "paths": [
        "configs/sources/governance/governance/checks.registry.json"
      ],
      "classification": "registry"
    },
    {
      "id": "GOV-RULE-007",
      "title": "scenario registry completeness",
      "severity": "high",
      "rule_type": "scenario_registry_complete",
      "paths": [
        "ops/e2e/scenarios/scenarios.json"
      ],
      "classification": "registry"
    },
    {
      "id": "GOV-RULE-008",
      "title": "ops artifact registry completeness",
      "severity": "medium",
      "rule_type": "ops_artifact_registry_complete",
      "paths": [
        "ops/k8s/generated/render-artifact-index.json"
      ],
      "classification": "deployment"
    },
    {
      "id": "GOV-RULE-009",
      "title": "release artifact registry completeness",
      "severity": "high",
      "rule_type": "release_artifact_registry_complete",
      "paths": [
        "ops/release/evidence/manifest.json"
      ],
      "classification": "registry"
    },
    {
      "id": "GOV-RULE-010",
      "title": "docs navigation consistency",
      "severity": "medium",
      "rule_type": "docs_navigation_consistent",
      "paths": [
        "mkdocs.yml"
      ],
      "classification": "documentation"
    },
    {
      "id": "GOV-RULE-011",
      "title": "governance foundation documents must exist",
      "severity": "high",
      "rule_type": "required_files_exist",
      "paths": [
        "docs/bijux-atlas/runtime/source-layout-and-ownership.md",
        "docs/bijux-atlas-dev/workspace/decision-records-and-ownership.md",
        "docs/bijux-atlas-dev/automation/automation-control-plane.md",
        "docs/bijux-atlas-dev/workspace/contributor-workflow.md"
      ],
      "classification": "documentation"
    },
    {
      "id": "GOV-RULE-012",
      "title": "contributor governance documents must exist",
      "severity": "high",
      "rule_type": "required_files_exist",
      "paths": [
        "docs/bijux-atlas-dev/workspace/contributor-workflow.md",
        "docs/bijux-atlas-dev/workspace/decision-records-and-ownership.md"
      ],
      "classification": "documentation"
    }
  ]
}
