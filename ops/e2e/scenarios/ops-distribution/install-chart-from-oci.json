{
  "schema_version": 1,
  "id": "install-chart-from-oci",
  "name": "Install chart from OCI",
  "environment": "kind",
  "profile": "kind",
  "chart_source": "oci://ghcr.io/bijux/charts/bijux-atlas",
  "image_source": "ghcr.io/bijux/bijux-atlas-server",
  "steps": [
    "helm pull oci://ghcr.io/bijux/charts/bijux-atlas --version v0.1.0",
    "helm install atlas ./bijux-atlas-0.1.0.tgz -f ops/k8s/values/kind.yaml",
    "kubectl wait --for=condition=Available deployment/atlas-bijux-atlas-server --timeout=180s"
  ],
  "evidence_path": "release/evidence/ops-distribution/install-chart-from-oci/evidence.json"
}
