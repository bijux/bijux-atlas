{
  "schema_version": 1,
  "id": "offline-install-from-bundle",
  "name": "Offline install from ops bundle",
  "environment": "kind",
  "profile": "offline",
  "bundle_source": "artifacts/release/ops/bundle/v0.1.0/ops-bundle-v0.1.0.tar.gz",
  "steps": [
    "tar -xzf ops-bundle-v0.1.0.tar.gz",
    "helm install atlas ./ops/k8s/charts/bijux-atlas -f ops/k8s/values/offline.yaml",
    "kubectl wait --for=condition=Available deployment/atlas-bijux-atlas-server --timeout=180s"
  ],
  "evidence_path": "ops/release/evidence/ops-distribution/offline-install-from-bundle/evidence.json"
}
