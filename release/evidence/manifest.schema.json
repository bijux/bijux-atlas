{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/release/evidence/manifest.schema.json",
  "title": "Release Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_by",
    "identity_path",
    "policy_path",
    "provenance",
    "chart_package",
    "image_artifacts",
    "docker_bases_lock",
    "toolchain_inventory",
    "auth_policy",
    "supply_chain",
    "docs_site_summary",
    "runtime_env_allowlist",
    "sboms",
    "scan_reports",
    "audit_assets",
    "governance_assets",
    "reports",
    "simulation_summaries",
    "drill_summaries",
    "evidence_tarball",
    "redacted_logs",
    "observability_assets",
    "perf_assets",
    "dataset_assets",
    "index_html"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "identity_path": {
      "type": "string",
      "minLength": 1
    },
    "policy_path": {
      "type": "string",
      "minLength": 1
    },
    "signature_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "chart_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "image_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_path",
          "profile"
        ],
        "properties": {
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "repository": {
            "type": "string"
          },
          "digest": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          }
        }
      }
    },
    "docker_bases_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "toolchain_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "auth_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auth_model",
        "access_policy"
      ],
      "properties": {
        "auth_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        },
        "access_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        }
      }
    },
    "supply_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_pins_report",
        "docs_toolchain_inventory"
      ],
      "properties": {
        "action_pins_report": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        },
        "docs_toolchain_inventory": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "docs_site_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "site_dir",
        "file_count"
      ],
      "properties": {
        "site_dir": {
          "type": "string",
          "minLength": 1
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "runtime_env_allowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "sboms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "format",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "format": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "image_ref": {
            "type": "string"
          }
        }
      }
    },
    "scan_reports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "format",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "format": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "audit_assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "retention_policy",
        "sample_log",
        "verification_report",
        "log_field_inventory"
      ],
      "properties": {
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "retention_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "sample_log": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "verification_report": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "log_field_inventory": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      }
    },
    "governance_assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exceptions_registry",
        "exceptions_archive",
        "exceptions_summary",
        "exceptions_expiry_warning",
        "exceptions_churn",
        "deprecations_summary",
        "compat_warnings",
        "breaking_changes",
        "governance_doctor",
        "institutional_delta",
        "institutional_delta_inputs"
      ],
      "properties": {
        "exceptions_registry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "exceptions_archive": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "exceptions_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "exceptions_expiry_warning": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "exceptions_churn": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "deprecations_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "compat_warnings": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "breaking_changes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "governance_doctor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "institutional_delta": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "institutional_delta_inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      }
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "simulation_summaries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "drill_summaries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_tarball": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "redacted_logs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "observability_assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
