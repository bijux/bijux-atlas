{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/release/evidence/manifest.schema.json",
  "title": "Release Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_by",
    "identity_path",
    "chart_package",
    "image_artifacts",
    "sboms",
    "reports",
    "simulation_summaries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "identity_path": {
      "type": "string",
      "minLength": 1
    },
    "chart_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "image_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_path",
          "profile"
        ],
        "properties": {
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "repository": {
            "type": "string"
          },
          "digest": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          }
        }
      }
    },
    "sboms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "format"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "format": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "simulation_summaries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
