{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/release/evidence/policy.schema.json",
  "title": "Release Evidence Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "required_paths",
    "require_prod_image_artifacts",
    "accepted_sbom_formats",
    "accepted_scan_report_formats",
    "cve_budget"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "required_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "require_prod_image_artifacts": {
      "type": "boolean"
    },
    "accepted_sbom_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "accepted_scan_report_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cve_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_critical",
        "max_high"
      ],
      "properties": {
        "max_critical": {
          "type": "integer",
          "minimum": 0
        },
        "max_high": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "cve_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "critical",
          "high",
          "expires_on",
          "justification"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "critical": {
            "type": "integer",
            "minimum": 0
          },
          "high": {
            "type": "integer",
            "minimum": 0
          },
          "expires_on": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "justification": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    }
  }
}
