{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bijux.dev/schema/release/evidence/policy.schema.json",
  "title": "Release Evidence Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "required_paths",
    "require_prod_image_artifacts",
    "accepted_sbom_formats",
    "accepted_scan_report_formats"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "required_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "require_prod_image_artifacts": {
      "type": "boolean"
    },
    "accepted_sbom_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "accepted_scan_report_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
